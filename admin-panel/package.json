{
  "name": "ad-player-pro",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.vrlogical.adplayerpro",
    "productName": "VRL Ad Player Pro",
    "files": [
      "dist/**/*",
      "main.js"
    ],
    "extraResources": [
      {
        "from": "./pocketbase.exe",
        "to": "pocketbase.exe"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "forceCodeSigning": false,
    "directories": {
      "output": "dist_electron"
    }
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "pdfjs-dist": "^5.4.530",
    "pocketbase": "^0.21.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-youtube": "^10.1.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "vite": "^7.0.0"
  }
}
